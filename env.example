# Postgres connection string, provided automatically when you add the
# Neon (or any Postgres) integration from the Vercel Storage tab.
DATABASE_URL=

# Blob read/write token, provided automatically when you add the
# Vercel Blob integration from the Vercel Storage tab.
BLOB_READ_WRITE_TOKEN=

# A long, random secret used to sign login session cookies. Generate one
# with `openssl rand -base64 32` and set it in your environment variables —
# never commit a real value here.
SESSION_SECRET=
